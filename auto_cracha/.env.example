# ============================================
# CrachApp - Variáveis de Ambiente
# ============================================

# Banco de Dados PostgreSQL
DATABASE_URL=postgresql://crachapp:sua_senha_super_secreta@postgres:5432/crachapp
POSTGRES_USER=crachapp
POSTGRES_PASSWORD=sua_senha_super_secreta
POSTGRES_DB=crachapp

# Redis Cache
REDIS_PASSWORD=sua_senha_redis_super_secreta

# Segurança (gerar: openssl rand -base64 32)
SECRET_KEY=sua_chave_secreta_super_longa_e_segura_aqui

# URLs da Aplicação
# Desenvolvimento:
APP_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000

# Produção (descomentar e atualizar):
# APP_URL=https://crachapp.com.br
# NEXT_PUBLIC_API_URL=https://crachapp.com.br

# Cloudinary (Upload de imagens)
# Formato: cloudinary://api_key:api_secret@cloud_name
CLOUDINARY_URL=cloudinary://seu_api_key:seu_api_secret@seu_cloud_name

# Mercado Pago (Pagamentos)
MERCADOPAGO_ACCESS_TOKEN=sua_access_token_mercado_pago

# Opcional: Webhook secret Mercado Pago
# MERCADOPAGO_WEBHOOK_SECRET=seu_webhook_secret
